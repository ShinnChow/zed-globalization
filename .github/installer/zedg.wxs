<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="ZedG"
           Language="1033"
           Version="$(var.AppVersion)"
           Manufacturer="zed-globalization"
           UpgradeCode="$(var.UpgradeCode)">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of ZedG is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="ZedG">
          <Directory Id="BinFolder" Name="bin" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="ZedG" />
      </Directory>
      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>

    <ComponentGroup Id="MainComponents" Directory="INSTALLFOLDER">
      <Component Id="ZedGExe">
        <File Source="$(var.SourceExe)" KeyPath="yes">
          <Shortcut Id="StartMenuShortcut"
                    Directory="AppMenuFolder"
                    Name="ZedG"
                    WorkingDirectory="INSTALLFOLDER"
                    Advertise="yes" />
        </File>
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="CliComponents" Directory="BinFolder">
      <Component Id="ZedGCli">
        <File Id="ZedGCliExe" Source="$(var.SourceCli)" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="DesktopShortcutComponents" Directory="DesktopFolder">
      <Component Id="DesktopShortcut">
        <Shortcut Id="DesktopShortcut"
                  Name="ZedG"
                  Target="[INSTALLFOLDER]ZedG.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\ZedG" Name="DesktopShortcut"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="Main" Title="ZedG" Level="1">
      <ComponentGroupRef Id="MainComponents" />
      <ComponentGroupRef Id="CliComponents" />
      <ComponentGroupRef Id="DesktopShortcutComponents" />
    </Feature>

  </Product>
</Wix>
